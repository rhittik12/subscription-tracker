  "version": "1.0.0",
  "description": "Personal Subscription Tracker API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "drizzle-kit generate",
